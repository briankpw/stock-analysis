# =============================================================================
# Key Stock — environment variables
# =============================================================================
# Two entrypoints read this file:
#   * `npm run dev` (or any local Node script) reads it via Next.js's built-in
#     env loader — copy to `.env.local` if you need overrides that shouldn't
#     be committed.
#   * `docker compose up` on the root `docker-compose.yml` reads it via
#     Compose's own env-file resolution.
#
# Every variable has a safe default baked into the stack files, so you only
# need to override the ones you actually care about.
# =============================================================================

# ---- Compose stack identity ------------------------------------------------
# Prefix used for container / volume / network names. Change if you want to
# run multiple copies on the same host (e.g. staging vs prod).
STACK_NAME=key-stock

# ---- Image ----------------------------------------------------------------
# Set to a registry ref (prefer a version tag over `latest`) to skip the
# local build. Leave the default for `docker compose up --build`.
IMAGE=key-stock:latest

# ---- Networking -----------------------------------------------------------
# The single port the UI listens on — used inside the container AND for
# the host-side mapping (both sides of `${APP_PORT}:${APP_PORT}` in the
# yml). Change it if 5001 collides with something else on the host.
APP_PORT=5001
TZ=UTC

# External Docker network that both containers attach to. Must already exist
# on the host — Compose will NOT create it (see `external: true` in the yml).
#
#   DOCKER_NETWORK=bridge          # Docker's default built-in network
#   DOCKER_NETWORK=traefik_proxy   # a pre-existing reverse-proxy network
#
# Create a custom one with:
#     docker network create traefik_proxy
DOCKER_NETWORK=bridge

# ---- Data persistence -----------------------------------------------------
# Where /app/data lives on the host. Accepts either:
#
#   1) A Docker named-volume name (default). Docker manages the storage.
#        DATA_MOUNT=key_stock_data
#
#   2) An absolute host path (bind mount). Must exist on the host. The
#      entrypoint script will chown it to PUID:PGID (below) on every
#      start, so you usually don't need to chown by hand.
#        DATA_MOUNT=/opt/keystock/data
DATA_MOUNT=key_stock_data

# ---- Runtime file ownership (LinuxServer.io convention) -------------------
# UID / GID the container runs as. The entrypoint script runs briefly as
# root at startup, chowns /app/data to PUID:PGID, then drops privileges
# via `su-exec` before exec-ing the Node process. This is what lets the
# same image work with any host uid/gid — set these to match the owner
# of your DATA_MOUNT directory:
#
#   On Linux:   id -u    # → PUID
#               id -g    # → PGID
#   On macOS:   id -u    # typically 501
#               id -g    # typically 20 (staff)
#
# Default 1000:1000 matches the first regular user on Ubuntu/Debian.
PUID=1000
PGID=1000

# ---- Public URL -----------------------------------------------------------
# The absolute URL the UI is served from — e.g. `https://stocks.example.com`
# behind a reverse proxy, or `http://192.168.1.5:5001` on a LAN. Optional;
# leave blank when the app is only ever hit at its container's host:port.
#
# When set, the CSRF middleware trusts APP_URL's host as an authoritative
# same-origin baseline, so mutations still work even if your reverse
# proxy rewrites the `Host` header (nginx does this if `proxy_set_header
# Host $host;` is missing, for example).
#
# Trailing slashes are stripped automatically; the value must parse as a
# full URL (scheme + host, plus optional port / path).
APP_URL=

# ---- Access control -------------------------------------------------------
# Two ways to lock the app down. Pick ONE — the credentials pair takes
# precedence when both are set.
#
#   1. Username + password (recommended for browser users). Login page
#      shows a two-field form; each request must present a valid
#      session cookie or `Authorization: Bearer <user>:<pass>` header.
#        APP_USERNAME=admin
#        APP_PASSWORD=<long-random-string>
#
#   2. Single bearer token (recommended for CLI / script callers).
#      Login page shows a single-field form.
#        APP_TOKEN=<long-random-string>
#
# Leave all three blank for a fully-open local install. STRONGLY set
# one of the modes if the UI port is reachable from the public internet.
# Generate a random secret with:  openssl rand -hex 32
APP_USERNAME=
APP_PASSWORD=
APP_TOKEN=

# ---- Ticker / defaults ----------------------------------------------------
STOCK_TICKER=KEYS
COMPANY_NAME=Keysight Technologies
DEFAULT_PERIOD=1y
DEFAULT_INTERVAL=1d

# ---- Caching --------------------------------------------------------------
CACHE_TTL_SECONDS=900

# Politician trades (STOCK Act) update daily-ish; 13F filings are quarterly.
# Cache aggressively — the datasets are chunky and SEC's 10 req/sec throttle
# will bite if you don't.
PORTFOLIO_CACHE_TTL_SECONDS=21600

# SEC requires a plain-text User-Agent identifying the requester on every
# EDGAR call. The app REFUSES to start in production if this still contains
# `example.com` — set it to a real contact email before any public deploy.
SEC_USER_AGENT=Key Stock Dashboard research@example.com

# ---- Paper trading --------------------------------------------------------
PAPER_STARTING_CASH=100000
PAPER_COMMISSION=0

# ---- Bot / worker ---------------------------------------------------------
BOT_LOOKBACK_PERIOD=1y
BOT_LOOKBACK_INTERVAL=1d
BOT_POLL_INTERVAL_SECONDS=900
BOT_DB_PATH=./data/bot.db

# Rolling age floor for notifications (days). Events whose date is older
# than this are silently skipped by every alert pipeline:
#   * News alerts     → uses the article's publishedAt
#   * Stock insider   → uses the Form 4 transactionDate (falls back to filingDate)
#   * Portfolio       → tradeDate for people/politicians, filingDate for funds
#                       (13F report period is always a quarter-end, so filing
#                        date is what matters for "just dropped")
# Default 2 = today + previous UTC day. Set to 0 to disable the gate and
# receive every re-syndicated headline / lagged PTR again.
BOT_NOTIFY_MAX_AGE_DAYS=2

# ---- Telegram alerts (optional) ------------------------------------------
# Two ways to provide the bot token:
#
#   1. Inline (simplest, but token is visible in `docker inspect`):
#        TELEGRAM_BOT_TOKEN=123456:AA...
#
#   2. Docker secret / mounted file (recommended for production). Bind-mount
#      the token file into the container yourself (e.g. via a compose override
#      or `docker secrets`) and point this at the mount path:
#        TELEGRAM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token
#
# Leave both blank to disable Telegram notifications — the worker will still
# record signals to SQLite; they just won't be pushed anywhere.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_FILE=
TELEGRAM_CHAT_ID=

# ---- Web Push notifications (PWA — optional) ------------------------------
# Every alert also fans out to any browser / installed PWA that opted in on
# the /bot page. Web Push signs each request with a VAPID keypair. On first
# boot the app generates one and persists it in the SQLite database, so
# leaving these blank is fine for a single-instance deploy.
#
# Override when:
#   * Scaling horizontally (all app containers must share the same keys).
#   * You want to pin the keys across container rebuilds.
#
# Generate a fresh pair with:
#   node -e "const w=require('web-push');const k=w.generateVAPIDKeys();console.log(k)"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact URL embedded in every push (RFC 8291). Must start with mailto: or https:
VAPID_SUBJECT=mailto:you@example.com

# ---- PWA ------------------------------------------------------------------
# When served behind an nginx reverse-proxy that maps /service-worker.js at
# the site root, override the default here so Chrome accepts the SW scope.
NEXT_PUBLIC_PWA_SW_URL=/service-worker.js

# ---- Backtest strategy tuning ---------------------------------------------
# Windows / thresholds for the three trend-following & mean-reversion
# strategies exposed on the /backtest page. Baked into the client bundle
# at build time (NEXT_PUBLIC_ prefix) so both the engine AND the strategy
# picker labels ("SMA Cross (50/200)" etc.) read from a single source —
# a container rebuild is required to pick up a change.
#
# Every knob has a safe fallback compiled into
# `lib/backtest-strategy-config.ts`; a missing or invalid value logs a
# warning and reverts to the default rather than breaking the page.
# Ordering constraints (`fast < slow`, `oversold < overbought`) are
# enforced likewise — an inverted pair is rejected and both reset to
# the defaults.
#
# Reasonable overrides:
#   * Shorter SMA windows (20/50) for a swing-trade style.
#   * Different RSI thresholds (20/80 for stricter reversion, 40/60 for
#     softer boundaries).
#
# ---- SMA Cross — fast must be strictly less than slow (defaults 50/200)
NEXT_PUBLIC_BACKTEST_SMA_FAST=50
NEXT_PUBLIC_BACKTEST_SMA_SLOW=200

# ---- EMA Cross — fast must be strictly less than slow (defaults 20/52)
NEXT_PUBLIC_BACKTEST_EMA_FAST=20
NEXT_PUBLIC_BACKTEST_EMA_SLOW=52

# ---- RSI Reversion — oversold must be strictly less than overbought
# (defaults 14/30/70). Thresholds accept any integer in [1, 99]; the
# RSI period accepts any integer in [2, 200].
NEXT_PUBLIC_BACKTEST_RSI_PERIOD=14
NEXT_PUBLIC_BACKTEST_RSI_OVERSOLD=30
NEXT_PUBLIC_BACKTEST_RSI_OVERBOUGHT=70

# ---- Alert defaults -------------------------------------------------------
# Initial daily-digest time pre-filled in the Signal / Resonance alert
# popovers when a user opens the config for a ticker they haven't yet
# subscribed to. 24-hour `HH:MM`, in the browser's local timezone. Users
# can still pick any time per alert — this only seeds the picker.
#
# Ships as 22:30 (10:30 PM) so a post-close digest lands in the evening
# on the Asia/Shanghai timezone the app was originally deployed in.
# Any value that isn't a valid `HH:MM` falls back to the compiled-in
# default rather than erroring out.
#
# Baked into the client bundle at build time — a container rebuild is
# required to pick up a change.
NEXT_PUBLIC_ALERT_DEFAULT_TIME=22:30
