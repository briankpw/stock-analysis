# =============================================================================
# Key Stock — environment variables
# =============================================================================
# Two entrypoints read this file:
#   * `npm run dev` (or any local Node script) reads it via Next.js's built-in
#     env loader — copy to `.env.local` if you need overrides that shouldn't
#     be committed.
#   * `docker compose up` on the root `docker-compose.yml` reads it via
#     Compose's own env-file resolution.
#
# Every variable has a safe default baked into the stack files, so you only
# need to override the ones you actually care about.
# =============================================================================

# ---- Compose stack identity ------------------------------------------------
# Prefix used for container / volume / network names. Change if you want to
# run multiple copies on the same host (e.g. staging vs prod).
STACK_NAME=key-stock

# ---- Image ----------------------------------------------------------------
# Set to a registry ref (prefer a version tag over `latest`) to skip the
# local build. Leave the default for `docker compose up --build`.
IMAGE=key-stock:latest

# ---- Networking -----------------------------------------------------------
# The single port the UI listens on — used inside the container AND for
# the host-side mapping (both sides of `${APP_PORT}:${APP_PORT}` in the
# yml). Change it if 5001 collides with something else on the host.
APP_PORT=5001
TZ=UTC

# External Docker network that both containers attach to. Must already exist
# on the host — Compose will NOT create it (see `external: true` in the yml).
#
#   DOCKER_NETWORK=bridge          # Docker's default built-in network
#   DOCKER_NETWORK=traefik_proxy   # a pre-existing reverse-proxy network
#
# Create a custom one with:
#     docker network create traefik_proxy
DOCKER_NETWORK=bridge

# ---- Data persistence -----------------------------------------------------
# Where /app/data lives on the host. Accepts either:
#
#   1) A Docker named-volume name (default). Docker manages the storage.
#        DATA_MOUNT=key_stock_data
#
#   2) An absolute host path (bind mount). Must exist on the host. The
#      entrypoint script will chown it to PUID:PGID (below) on every
#      start, so you usually don't need to chown by hand.
#        DATA_MOUNT=/opt/keystock/data
DATA_MOUNT=key_stock_data

# ---- Runtime file ownership (LinuxServer.io convention) -------------------
# UID / GID the container runs as. The entrypoint script runs briefly as
# root at startup, chowns /app/data to PUID:PGID, then drops privileges
# via `su-exec` before exec-ing the Node process. This is what lets the
# same image work with any host uid/gid — set these to match the owner
# of your DATA_MOUNT directory:
#
#   On Linux:   id -u    # → PUID
#               id -g    # → PGID
#   On macOS:   id -u    # typically 501
#               id -g    # typically 20 (staff)
#
# Default 1000:1000 matches the first regular user on Ubuntu/Debian.
PUID=1000
PGID=1000

# ---- Access control -------------------------------------------------------
# When APP_TOKEN is set, every /api/* call (except the healthcheck at
# /api/health) must present it as `Authorization: Bearer <token>` or the
# `app_token` cookie. Leave empty for a fully-open local install.
#
# Generate one with:  openssl rand -hex 32
# STRONGLY recommended if the UI port is reachable from the public internet.
APP_TOKEN=

# ---- Ticker / defaults ----------------------------------------------------
STOCK_TICKER=KEYS
COMPANY_NAME=Keysight Technologies
DEFAULT_PERIOD=1y
DEFAULT_INTERVAL=1d

# ---- Caching --------------------------------------------------------------
CACHE_TTL_SECONDS=900

# Politician trades (STOCK Act) update daily-ish; 13F filings are quarterly.
# Cache aggressively — the datasets are chunky and SEC's 10 req/sec throttle
# will bite if you don't.
PORTFOLIO_CACHE_TTL_SECONDS=21600

# SEC requires a plain-text User-Agent identifying the requester on every
# EDGAR call. The app REFUSES to start in production if this still contains
# `example.com` — set it to a real contact email before any public deploy.
SEC_USER_AGENT=Key Stock Dashboard research@example.com

# ---- Paper trading --------------------------------------------------------
PAPER_STARTING_CASH=100000
PAPER_COMMISSION=0

# ---- Bot / worker ---------------------------------------------------------
BOT_LOOKBACK_PERIOD=1y
BOT_LOOKBACK_INTERVAL=1d
BOT_POLL_INTERVAL_SECONDS=900
BOT_DB_PATH=./data/bot.db

# ---- Telegram alerts (optional) ------------------------------------------
# Two ways to provide the bot token:
#
#   1. Inline (simplest, but token is visible in `docker inspect`):
#        TELEGRAM_BOT_TOKEN=123456:AA...
#
#   2. Docker secret / mounted file (recommended for production). Bind-mount
#      the token file into the container yourself (e.g. via a compose override
#      or `docker secrets`) and point this at the mount path:
#        TELEGRAM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token
#
# Leave both blank to disable Telegram notifications — the worker will still
# record signals to SQLite; they just won't be pushed anywhere.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_FILE=
TELEGRAM_CHAT_ID=

# ---- PWA ------------------------------------------------------------------
# When served behind an nginx reverse-proxy that maps /service-worker.js at
# the site root, override the default here so Chrome accepts the SW scope.
NEXT_PUBLIC_PWA_SW_URL=/service-worker.js
