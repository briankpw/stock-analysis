# =====================================================
# Key Stock \u2014 environment variables (copy to .env.local)
# =====================================================

# --------- Ticker / defaults ----------
STOCK_TICKER=KEYS
COMPANY_NAME=Keysight Technologies
DEFAULT_PERIOD=1y
DEFAULT_INTERVAL=1d
TZ=UTC

# --------- Cache ----------
CACHE_TTL_SECONDS=900

# --------- Portfolios (politicians + fund managers) ----------
# Cache TTL for STOCK Act datasets and SEC 13F filings. Both update on a
# multi-hour cadence at best; 6h is a sensible default.
PORTFOLIO_CACHE_TTL_SECONDS=21600
# SEC requires a plain-text User-Agent identifying the requester on every
# request; put a real contact email here if you deploy this publicly.
SEC_USER_AGENT=Key Stock Dashboard research@example.com

# --------- Paper trading ----------
PAPER_STARTING_CASH=100000
PAPER_COMMISSION=0

# --------- Bot / worker ----------
BOT_LOOKBACK_PERIOD=1y
BOT_LOOKBACK_INTERVAL=1d
BOT_POLL_INTERVAL_SECONDS=900
BOT_DB_PATH=./data/bot.db

# --------- Telegram alerts ----------
# Get a bot token from @BotFather, then grab your chat id from
# @userinfobot on Telegram. Leave blank to disable alerts.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --------- PWA ----------
# When served behind an nginx reverse-proxy that maps /service-worker.js at
# the site root, override the default here so Chrome accepts the SW scope.
NEXT_PUBLIC_PWA_SW_URL=/service-worker.js
