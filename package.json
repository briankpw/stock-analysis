{
  "name": "key-stock",
  "version": "1.0.0",
  "private": true,
  "description": "Keysight Technologies (KEYS) stock analysis dashboard — Next.js 15 rewrite.",
  "scripts": {
    "dev": "next dev -p 5001",
    "build": "next build",
    "start": "next start -p 5001",
    "worker": "tsx worker.ts",
    "dev:all": "concurrently -k -n ui,worker -c blue,magenta \"npm run dev\" \"npm run worker\"",
    "start:all": "concurrently -k -n ui,worker -c blue,magenta \"npm run start\" \"npm run worker\"",
    "typecheck": "tsc --noEmit",
    "lint": "next lint",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-tooltip": "^1.1.4",
    "better-sqlite3": "^11.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "fflate": "^0.8.3",
    "lightweight-charts": "^4.2.1",
    "lucide-react": "^0.460.0",
    "next": "^15.0.3",
    "next-themes": "^0.4.3",
    "react": "^19.0.0-rc-02c0e824-20241028",
    "react-dom": "^19.0.0-rc-02c0e824-20241028",
    "recharts": "^2.13.3",
    "tailwind-merge": "^2.5.4",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.23.1",
    "vader-sentiment": "^1.1.3",
    "yahoo-finance2": "^3.15.4",
    "zod": "^3.23.8",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "eslint": "^9.15.0",
    "eslint-config-next": "^15.0.3",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vitest": "^2.1.5"
  },
  "engines": {
    "node": ">=18.18"
  }
}
