# =============================================================================
# Key Stock — Portainer stack env template
# =============================================================================
# Copy the block below into Portainer:
#   Stacks -> (your stack) -> Environment variables -> "Advanced mode"
# and edit values inline. Every variable has a sensible default in stack.yml,
# so you only need to override the ones you actually care about.
# =============================================================================

# ---- Stack identity --------------------------------------------------------
# Prefix used for container / volume / network names. Change it if you want to
# run multiple stacks on the same host (e.g. staging vs prod).
STACK_NAME=key-stock

# ---- Image -----------------------------------------------------------------
# Prefer a specific version tag over `latest` — that way `Pull and redeploy`
# is a deliberate action rather than an accidental base-image bump. If you
# build from git (Option A in README), leave this pointing at the local
# image tag that Portainer will produce.
#
# Examples:
#   IMAGE=key-stock:latest                       # local build (default)
#   IMAGE=ghcr.io/<owner>/key-stock:1.0.0        # pinned registry image
#   IMAGE=ghcr.io/<owner>/key-stock@sha256:…     # fully immutable
IMAGE=key-stock:latest

# ---- Networking ------------------------------------------------------------
# Host port that the UI is exposed on. Change if 5001 is already taken.
UI_PORT=5001
TZ=UTC

# ---- Access control --------------------------------------------------------
# When APP_TOKEN is set, every /api/* call (except the healthcheck at
# /api/health) must present it as `Authorization: Bearer <token>` or the
# `app_token` cookie. Leave empty for a fully-open local install.
#
# Generate one with:  openssl rand -hex 32
# STRONGLY recommended if the UI port is reachable from the public internet.
APP_TOKEN=

# ---- Ticker / defaults -----------------------------------------------------
STOCK_TICKER=KEYS
COMPANY_NAME=Keysight Technologies
DEFAULT_PERIOD=1y
DEFAULT_INTERVAL=1d

# ---- Caching ---------------------------------------------------------------
CACHE_TTL_SECONDS=900
PORTFOLIO_CACHE_TTL_SECONDS=21600

# SEC EDGAR requires a plain-text User-Agent identifying the requester. Put a
# REAL contact email here before deploying publicly. The app now fails to
# start (loudly) if this still contains `example.com`, so you can't forget.
SEC_USER_AGENT=Key Stock Dashboard research@example.com

# ---- Paper trading ---------------------------------------------------------
PAPER_STARTING_CASH=100000
PAPER_COMMISSION=0

# ---- Bot worker ------------------------------------------------------------
BOT_LOOKBACK_PERIOD=1y
BOT_LOOKBACK_INTERVAL=1d
BOT_POLL_INTERVAL_SECONDS=900

# ---- Telegram alerts (optional) -------------------------------------------
# Two ways to provide the bot token:
#
#   1. Inline (simplest, but token is visible in `docker inspect`):
#        TELEGRAM_BOT_TOKEN=123456:AA...
#
#   2. Docker secret / mounted file (recommended for production). Bind-mount
#      the token file into the container yourself (e.g. via a compose override
#      or `docker secrets`) and point this at the mount path:
#        TELEGRAM_BOT_TOKEN_FILE=/run/secrets/telegram_bot_token
#
# Leave both blank to disable Telegram notifications — the worker will still
# record signals to SQLite; they just won't be pushed anywhere.
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_TOKEN_FILE=
TELEGRAM_CHAT_ID=
